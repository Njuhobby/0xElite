# =============================================================================
# 0xElite Shared Environment Variables
# Copy this file to .env and fill in the values
# Used by: backend, contracts (hardhat)
# Note: frontend uses its own .env.local (NEXT_PUBLIC_ prefix)
# =============================================================================

# Blockchain RPC
RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_API_KEY
RPC_TYPE=polling

# Deployer / Backend Service Wallet
PRIVATE_KEY=your_private_key_here

# Contract Addresses (filled after deployment)
USDC_ADDRESS=0x...
STAKE_VAULT_ADDRESS=0x...
ESCROW_VAULT_ADDRESS=0x...
PROJECT_MANAGER_ADDRESS=0x...
DISPUTE_DAO_ADDRESS=0x...
ELITE_TOKEN_ADDRESS=0x...

# Deployment Config
TREASURY_ADDRESS=0x...
PLATFORM_FEE_BPS=1000

# Etherscan (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Database (backend only)
DATABASE_URL=postgresql://postgres:oxelite123@localhost:5432/oxelite_dev

# Event Sync (backend only)
START_BLOCK=0
POLLING_INTERVAL=12000
BATCH_SIZE=1000
CONFIRMATIONS=2
RETRY_ATTEMPTS=3
RETRY_DELAY=5000
HEALTH_CHECK_INTERVAL=30000
ALERT_ERROR_COUNT=5

# Admin
ADMIN_ADDRESSES=0xAdminWallet1,0xAdminWallet2

# Server (backend only)
PORT=3001
NODE_ENV=development

# CORS (backend only)
ALLOWED_ORIGINS=http://localhost:3000
